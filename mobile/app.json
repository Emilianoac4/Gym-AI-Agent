{
  "expo": {
    "name": "GymAI",
    "slug": "gymai-mobile",
    "owner": "ealfaroc",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.gymai.mobile",
      "usesAppleSignIn": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#463C33",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
