{
  "name": "backend",
  "version": "1.0.0",
  "description": "GymAI backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:ai:local": "powershell -ExecutionPolicy Bypass -File ./scripts/ai-iteration-validation.ps1",
    "test:block1": "jest --runInBand tests/security/user-delete-financial-integrity.test.ts",
    "test:block1:ai:cross": "powershell -ExecutionPolicy Bypass -File ./scripts/block1-ai-cross-validation.ps1",
    "test:security": "jest --runInBand tests/security",
    "test:e2e:payments": "node scripts/e2e-payments-flow.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "prisma": "^6.14.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
