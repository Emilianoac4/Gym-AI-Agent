PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:8081"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Optional: comma-separated client IDs/audiences to validate social tokens
GOOGLE_OAUTH_CLIENT_IDS=""
APPLE_OAUTH_AUDIENCES=""
AUTH_ALLOW_UNVERIFIED_SOCIAL_EMAIL="false"
APP_BASE_URL="https://tu-dominio-app.com"
# Required for email verification and password reset delivery
RESEND_API_KEY=""
EMAIL_FROM="noreply@tu-dominio.com"
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES="60"
PASSWORD_RESET_TOKEN_TTL_MINUTES="30"
DAILY_MEMBERSHIP_SUMMARY_ENABLED="false"
DAILY_MEMBERSHIP_SUMMARY_HOUR_UTC="23"

OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_MODEL_CHAT="gpt-5.4-mini"
OPENAI_MODEL_ROUTINE="gpt-5.4-mini"
OPENAI_MODEL_NUTRITION="gpt-5.4-mini"
OPENAI_MODEL_TIP="gpt-5.4-mini"
OPENAI_MODEL_FALLBACK="gpt-4o-mini"
OPENAI_CHAT_CONTEXT_TURNS="12"
OPENAI_CHAT_CONTEXT_MAX_CHARS="500"
OPENAI_CHAT_MAX_TOKENS="800"
AI_DAILY_TOKEN_DEGRADATION_THRESHOLD="20000"
AI_DAILY_TOKEN_LIMIT_PER_USER="0"
