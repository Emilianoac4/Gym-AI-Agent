// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  trainer
  member
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum PermissionGrantAction {
  availability_write
  notifications_send
}

model GlobalUserAccount {
  id                              String    @id @default(uuid())
  email                           String    @unique
  passwordHash                    String    @map("password_hash")
  fullName                        String    @map("full_name")
  isActive                        Boolean   @default(true) @map("is_active")
  emailVerifiedAt                 DateTime? @map("email_verified_at")
  emailVerificationLastSentAt     DateTime? @map("email_verification_last_sent_at")
  emailVerificationTokenHash      String?   @map("email_verification_token_hash")
  emailVerificationTokenExpiresAt DateTime? @map("email_verification_token_expires_at")
  passwordResetTokenHash          String?   @map("password_reset_token_hash")
  passwordResetTokenExpiresAt     DateTime? @map("password_reset_token_expires_at")
  createdAt                       DateTime  @default(now()) @map("created_at")
  updatedAt                       DateTime  @updatedAt @map("updated_at")

  memberships User[]

  @@map("global_user_accounts")
}

model Gym {
  id        String   @id @default(uuid())
  name      String
  ownerName String   @map("owner_name")
  address   String?
  phone     String?
  currency  String   @default("USD")
  country   String?
  state     String?
  district  String?
  deletedAt DateTime? @map("deleted_at")
  recoverUntil DateTime? @map("recover_until")
  deletedByPlatformUserId String? @map("deleted_by_platform_user_id")
  deletionPendingAt DateTime? @map("deletion_pending_at")
  deletionChallengeHash String? @map("deletion_challenge_hash")
  deletionChallengeExpiresAt DateTime? @map("deletion_challenge_expires_at")
  deletionRequestedByPlatformUserId String? @map("deletion_requested_by_platform_user_id")
  createdAt DateTime @default(now()) @map("created_at")

  users User[]

  @@map("gyms")
}

model User {
  id                String      @id @default(uuid())
  gymId             String      @map("gym_id")
  globalUserId      String      @map("global_user_id")
  email             String
  username          String?     @unique
  fullName          String      @map("full_name")
  role              UserRole    @default(member)
  membershipStartAt DateTime?   @map("membership_start_at")
  membershipEndAt   DateTime?   @map("membership_end_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  isActive          Boolean     @default(true) @map("is_active")

  gym           Gym                @relation(fields: [gymId], references: [id], onDelete: Cascade)
  globalAccount GlobalUserAccount  @relation(fields: [globalUserId], references: [id], onDelete: Cascade)
  profile       UserProfile?
  measurements  Measurement[]
  healthConnections UserHealthConnection[]

  @@index([gymId])
  @@index([globalUserId])
  @@map("users")
}

model UserProfile {
  id             String    @id @default(uuid())
  userId         String    @unique @map("user_id")
  gender         String?   @map("gender")
  birthDate      DateTime? @map("birth_date")
  heightCm       Float?    @map("height_cm")
  goal           String?
  medicalConds   String?   @map("medical_conds")
  injuries       String?
  experienceLvl  String?   @map("experience_lvl")
  availability   String?
  dietPrefs      String?   @map("diet_prefs")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Measurement {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  date       DateTime  @default(now())
  weightKg   Float?    @map("weight_kg")
  bodyFatPct Float?    @map("body_fat_pct")
  muscleMass Float?    @map("muscle_mass")
  chestCm    Float?    @map("chest_cm")
  waistCm    Float?    @map("waist_cm")
  hipCm      Float?    @map("hip_cm")
  armCm      Float?    @map("arm_cm")
  photoUrl   String?   @map("photo_url")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("measurements")
}

enum AIChatLogType {
  CHAT
  ROUTINE_GENERATION
  NUTRITION_GENERATION
  DAILY_TIP
}

enum HealthProvider {
  apple_health
  google_fit
  health_connect
}

enum MembershipTransactionType {
  activation
  renewal
}

enum PaymentMethod {
  card
  transfer
  cash
}

enum SubscriptionPlanTier {
  basica
  standard
  premium
}

enum GymSubscriptionStatus {
  active
  grace
  suspended
  cancelled
}

model UserHealthConnection {
  id                      String         @id @default(uuid())
  userId                  String         @map("user_id")
  provider                HealthProvider
  externalEmail           String?        @map("external_email")
  externalSubject         String?        @map("external_subject")
  metadata                String?
  isActive                Boolean        @default(true) @map("is_active")
  linkedAt                DateTime       @default(now()) @map("linked_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_health_connections")
}

model AIChatLog {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  type        AIChatLogType
  userMessage String        @map("user_message")
  aiResponse  String        @map("ai_response")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("ai_chat_logs")
}

model MembershipTransaction {
  id                String                    @id @default(uuid())
  gymId             String                    @map("gym_id")
  userId            String                    @map("user_id")
  actorUserId       String                    @map("actor_user_id")
  type              MembershipTransactionType
  paymentMethod     PaymentMethod             @map("payment_method")
  amount            Float
  currency          String                    @default("USD")
  membershipMonths  Int                       @map("membership_months")
  membershipStartAt DateTime                  @map("membership_start_at")
  membershipEndAt   DateTime                  @map("membership_end_at")
  createdAt         DateTime                  @default(now()) @map("created_at")

  @@map("membership_transactions")
}

model MembershipDailySummaryDispatch {
  id         String   @id @default(uuid())
  gymId      String   @map("gym_id")
  summaryDay DateTime @map("summary_day")
  sentAt     DateTime @default(now()) @map("sent_at")

  @@unique([gymId, summaryDay])
  @@map("membership_daily_summary_dispatches")
}

model GymScheduleTemplate {
  id              String    @id @default(uuid())
  gymId           String    @map("gym_id")
  dayOfWeek       DayOfWeek @map("day_of_week")
  isOpen          Boolean   @default(true) @map("is_open")
  opensAt         String?   @map("opens_at")
  closesAt        String?   @map("closes_at")
  opensAtSecondary String?  @map("opens_at_secondary")
  closesAtSecondary String? @map("closes_at_secondary")
  slotMinutes     Int       @default(60) @map("slot_minutes")
  capacityLabel   String?   @map("capacity_label")
  createdByUserId String    @map("created_by_user_id")
  updatedByUserId String    @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([gymId, dayOfWeek])
  @@map("gym_schedule_templates")
}

model GymScheduleException {
  id              String   @id @default(uuid())
  gymId           String   @map("gym_id")
  date            DateTime @map("date")
  isClosed        Boolean  @default(false) @map("is_closed")
  opensAt         String?  @map("opens_at")
  closesAt        String?  @map("closes_at")
  opensAtSecondary String? @map("opens_at_secondary")
  closesAtSecondary String? @map("closes_at_secondary")
  slotMinutes     Int?     @map("slot_minutes")
  capacityLabel   String?  @map("capacity_label")
  note            String?
  createdByUserId String   @map("created_by_user_id")
  updatedByUserId String   @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([gymId, date])
  @@map("gym_schedule_exceptions")
}

model UserPermissionGrant {
  id               String                @id @default(uuid())
  userId           String                @map("user_id")
  permissionAction PermissionGrantAction @map("permission_action")
  grantedByUserId  String                @map("granted_by_user_id")
  createdAt        DateTime              @default(now()) @map("created_at")

  @@unique([userId, permissionAction])
  @@map("user_permission_grants")
}

model TrainerPresenceSession {
  id            String    @id @default(uuid())
  gymId         String    @map("gym_id")
  trainerUserId String    @map("trainer_user_id")
  startedAt     DateTime  @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([gymId, startedAt])
  @@index([trainerUserId, endedAt])
  @@map("trainer_presence_sessions")
}

model MembershipReportExport {
  id                String   @id @default(uuid())
  gymId             String   @map("gym_id")
  generatedByUserId String   @map("generated_by_user_id")
  periodDays        Int      @map("period_days")
  rowCount          Int      @map("row_count")
  csvContent        String   @map("csv_content")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([gymId, createdAt])
  @@map("membership_report_exports")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  gymId     String   @map("gym_id")
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([gymId])
  @@map("push_tokens")
}

model GeneralNotification {
  id           String   @id @default(uuid())
  gymId        String   @map("gym_id")
  sentByUserId String   @map("sent_by_user_id")
  title        String
  body         String
  category     String   @default("general")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([gymId, createdAt])
  @@map("general_notifications")
}

model MessageThread {
  id          String    @id @default(uuid())
  gymId       String    @map("gym_id")
  adminUserId String    @map("admin_user_id")
  memberId    String    @map("member_id")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  messages DirectMessage[]

  @@index([gymId, memberId])
  @@index([gymId, adminUserId])
  @@map("message_threads")
}

model DirectMessage {
  id           String    @id @default(uuid())
  threadId     String    @map("thread_id")
  senderUserId String    @map("sender_user_id")
  body         String
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("direct_messages")
}

model EmergencyTicket {
  id              String    @id @default(uuid())
  gymId           String    @map("gym_id")
  reporterUserId  String    @map("reporter_user_id")
  category        String
  description     String
  status          String    @default("open")
  resolvedByUserId String?  @map("resolved_by_user_id")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([gymId, status, createdAt])
  @@index([reporterUserId, createdAt])
  @@map("emergency_tickets")
}

model GymSubscription {
  id            String                @id @default(uuid())
  gymId         String                @unique @map("gym_id")
  planTier      SubscriptionPlanTier  @map("plan_tier")
  userLimit     Int                   @map("user_limit")
  status        GymSubscriptionStatus @default(active)
  startsAt      DateTime              @map("starts_at")
  endsAt        DateTime              @map("ends_at")
  graceStartedAt DateTime?            @map("grace_started_at")
  graceEndsAt   DateTime?             @map("grace_ends_at")
  notes         String?
  updatedBy     String?               @map("updated_by")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@index([status, endsAt])
  @@map("gym_subscriptions")
}

model GymSubscriptionAudit {
  id               String                @id @default(uuid())
  gymId            String                @map("gym_id")
  action           String
  previousPlanTier SubscriptionPlanTier? @map("previous_plan_tier")
  newPlanTier      SubscriptionPlanTier? @map("new_plan_tier")
  previousUserLimit Int?                 @map("previous_user_limit")
  newUserLimit     Int?                  @map("new_user_limit")
  previousEndsAt   DateTime?             @map("previous_ends_at")
  newEndsAt        DateTime?             @map("new_ends_at")
  reason           String?
  createdBy        String                @map("created_by")
  createdAt        DateTime              @default(now()) @map("created_at")

  @@index([gymId, createdAt])
  @@map("gym_subscription_audits")
}

model PlatformAdminUser {
  id          String   @id @default(uuid())
  email       String   @unique
  passwordHash String  @map("password_hash")
  fullName    String   @map("full_name")
  usernames   String[] @default([])
  isActive    Boolean  @default(true) @map("is_active")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("platform_admin_users")
}
